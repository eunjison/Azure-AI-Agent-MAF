# Azure OpenAI Configuration
# Microsoft Agent Framework에서 사용하는 환경변수

# Azure OpenAI Endpoint
# 예: https://your-resource-name.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# Azure OpenAI API Key
AZURE_OPENAI_API_KEY=your-api-key-here

# Azure OpenAI Chat Deployment Name
# 배포된 모델 이름 (예: gpt-4o-mini, gpt-4o, gpt-35-turbo)
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o-mini

# Azure OpenAI API Version
AZURE_OPENAI_API_VERSION=2024-10-21

# Optional: Additional API Keys for Tools
# 웹 검색 도구를 사용하는 경우
SERP_API_KEY=your-serpapi-key-here

# 날씨 정보를 사용하는 경우
OPENWEATHER_API_KEY=your-openweather-api-key-here

# Google Custom Search를 사용하는 경우
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CSE_ID=your-google-cse-id-here

# 환율 정보를 사용하는 경우
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key-here

# Optional: Azure Identity Configuration
# Azure CLI 또는 Managed Identity를 사용하는 경우 아래 설정은 불필요합니다
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# Optional: Azure AI Project Configuration
# Azure AI Foundry를 사용하는 경우
# AZURE_AI_PROJECT_ENDPOINT=https://your-project.api.azureml.ms
# AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# Optional: Logging and Debugging
# 로그 레벨 설정 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# OpenTelemetry 추적 활성화
ENABLE_TELEMETRY=false

# Optional: Workflow Checkpoint Storage
# 워크플로우 체크포인트 저장 경로
CHECKPOINT_DIR=./checkpoints

# Optional: Code Execution Settings
# 코드 실행 시 작업 디렉토리
CODE_EXECUTION_WORK_DIR=./workspace

# 코드 실행 타임아웃 (초)
CODE_EXECUTION_TIMEOUT=30
